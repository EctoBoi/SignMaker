{
    "name": "signmaker",
    "version": "1.7.0",
    "description": "Creates signage",
    "keywords": [
        "signage",
        "utility"
    ],
    "homepage": "https://sign-maker.netlify.app",
    "bugs": {
        "url": "https://github.com/EctoBoi/SignMaker/issues"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/EctoBoi/SignMaker.git"
    },
    "license": "ISC",
    "author": "Justin Banton",
    "type": "module",
    "main": "src/main.ts",
    "scripts": {
        "dev:client": "vite",
        "dev:server": "tsx watch server/index.ts",
        "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
        "build": "tsc && vite build",
        "preview": "vite preview",
        "deploy": "tsc && vite build && netlify deploy --prod --dir=dist"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/node": "^25.9.3",
        "concurrently": "^10.0.3",
        "eslint": "^10.5.0",
        "globals": "^17.6.0",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0",
        "vite": "^8.0.16"
    },
    "dependencies": {
        "cors": "^2.8.6",
        "express": "^5.2.1",
        "jsbarcode": "^3.12.3"
    }
}
